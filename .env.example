# ─── Clés de l'outil interne de concepts ───────────────────────────
# Copie ce fichier en ".env" et remplis les clés.

# Claude (analyse + génération). Si vide, l'outil réutilise
# automatiquement la clé de ../creatikk_demo_server/.env
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq — transcription Whisper (GRATUIT). https://console.groq.com/keys
GROQ_API_KEY=

# (Optionnel) API TikTok fiable via RapidAPI. Si vide, l'outil utilise
# l'API publique gratuite tikwm (suffisante pour tester, moins robuste).
RAPIDAPI_KEY=
RAPIDAPI_HOST=

PORT=8790
